# Example Environment Variables

# Database connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your_password

# API Keys
API_KEY_SERVICE_X=your_api_key_service_x
API_KEY_SERVICE_Y=your_api_key_service_y

# Application settings
APP_PORT=3000
APP_ENV=development
